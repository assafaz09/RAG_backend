# RAG AI System Environment Variables

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/rag_ai_db

# Supabase Configuration
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://[user]:[password]@[host]:[port]/[database]
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_PUBLIC_KEY=your-supabase-jwt-public-key

# Google OAuth (configured in Supabase)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=rag_collection

# Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=rag_documents

# Hybrid Search Configuration
HYBRID_SEARCH_VECTOR_WEIGHT=0.5
HYBRID_SEARCH_KEYWORD_WEIGHT=0.5
HYBRID_SEARCH_TOP_K=10

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379

# Frontend Environment Variables
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
